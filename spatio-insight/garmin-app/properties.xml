  <property id="Weight" type="number">0</property>
  <property id="BirthYear" type="number">0</property>
  <property id="BirthMonth" type="number">0</property>
  <property id="BirthDay" type="number">0</property>
  <property id="ArmSpan" type="number">0</property>

</properties>
